{application, beam_agent, [
    {description, "Canonical BEAM agent SDK with internal backend implementations"},
    {vsn, "0.1.0"},
    {registered, []},
    {applications, [
        kernel,
        stdlib,
        crypto,
        ssl,
        inets,
        public_key
    ]},
    {env, []},
    {licenses, ["MIT"]},
    {links, [{"GitHub", "https://github.com/beardedeagle/beam-agent"}]},
    {modules, [
        beam_agent,
        beam_agent_capabilities,
        beam_agent_catalog,
        beam_agent_checkpoint,
        beam_agent_command,
        beam_agent_content,
        beam_agent_control,
        beam_agent_hooks,
        beam_agent_mcp,
        beam_agent_raw,
        beam_agent_runtime,
        beam_agent_session_store,
        beam_agent_telemetry,
        beam_agent_threads,
        beam_agent_account,
        beam_agent_apps,
        beam_agent_config,
        beam_agent_file,
        beam_agent_provider,
        beam_agent_search,
        beam_agent_skills,
        beam_agent_core,
        beam_agent_backend,
        beam_agent_behaviour,
        beam_agent_catalog_core,
        beam_agent_checkpoint_core,
        beam_agent_collaboration,
        beam_agent_command_core,
        beam_agent_config_core,
        beam_agent_content_core,
        beam_agent_control_core,
        beam_agent_ets,
        beam_agent_events,
        beam_agent_hooks_core,
        beam_agent_attachments,
        beam_agent_jsonl,
        beam_agent_jsonrpc,
        beam_agent_tool_registry,
        beam_agent_mcp_protocol,
        beam_agent_mcp_dispatch,
        beam_agent_mcp_client_dispatch,
        beam_agent_mcp_transport_http,
        beam_agent_mcp_transport_stdio,
        beam_agent_raw_core,
        beam_agent_router,
        beam_agent_runtime_core,
        beam_agent_session_store_core,
        beam_agent_table_owner,
        beam_agent_telemetry_core,
        beam_agent_threads_core,
        beam_agent_todo,
        beam_agent_session_engine,
        beam_agent_session_handler,
        beam_agent_transport,
        beam_agent_transport_port,
        beam_agent_transport_ws,
        beam_agent_ws_frame,
        beam_agent_ws_client,
        beam_agent_http_client,
        beam_agent_account_core,
        beam_agent_app_core,
        beam_agent_file_core,
        beam_agent_search_core,
        beam_agent_skills_core,
        claude_agent_sdk,
        claude_agent_session,
        claude_session_handler,
        claude_session_store,
        codex_app_server,
        codex_exec,
        codex_port_utils,
        codex_protocol,
        codex_realtime_protocol,
        codex_realtime_session,
        codex_realtime_session_handler,
        codex_session,
        codex_session_handler,
        copilot_client,
        copilot_frame,
        copilot_protocol,
        copilot_session,
        copilot_session_handler,
        beam_agent_gemini_reverse_requests,
        beam_agent_gemini_translate,
        beam_agent_gemini_wire,
        gemini_cli_client,
        gemini_cli_protocol,
        gemini_cli_session,
        gemini_session_handler,
        opencode_client,
        opencode_http,
        opencode_protocol,
        opencode_session,
        opencode_session_handler,
