{erl_opts, [debug_info, warn_missing_spec, warnings_as_errors]}

.
{src_dirs,
 ["src",
  "src/public",
  "src/core",
  "src/transports",
  "src/backends/claude",
  "src/backends/codex",
  "src/backends/copilot",
  "src/backends/gemini",
  "src/backends/opencode"]}

.
{deps, []}

.
{dialyzer,
 [{warnings, [error_handling, underspecs, unmatched_returns]},
  {plt_extra_apps, [inets, ssl, crypto, public_key]}]}

.
{profiles,
 [{test,
   [{deps, [{proper, "~> 1.4"}, {telemetry, "~> 1.3"}]},
    {extra_src_dirs,
     ["test/contract",
      "test/conformance",
      "test/public",
      "test/core",
      "test/backends/claude",
      "test/backends/codex",
      "test/backends/copilot",
      "test/backends/gemini",
      "test/backends/opencode"]},
    {erl_opts, [nowarn_export_all, nowarn_missing_spec]}]}]}

.
{project_plugins, [{rebar3_hex, "~> 7.0"}, {rebar3_ex_doc, "~> 0.2"}]}

.
{hex, [{doc, #{provider => ex_doc}}]}

.
{ex_doc,
 [{extras,
   ["README.md", "docs/guides/backend_integration_guide.md", "CONTRIBUTING.md", "LICENSE"]},
  {main, <<"README.md">>},
  {source_url, <<"https://github.com/beardedeagle/beam-agent">>},
  {groups_for_modules,
   [{<<"Public API">>,
     [beam_agent,
      beam_agent_capabilities,
      beam_agent_catalog,
      beam_agent_checkpoint,
      beam_agent_command,
      beam_agent_content,
      beam_agent_control,
      beam_agent_hooks,
      beam_agent_mcp,
      beam_agent_raw,
      beam_agent_runtime,
      beam_agent_session_store,
      beam_agent_telemetry,
      beam_agent_threads]},
    {<<"Core Types">>,
     [beam_agent_backend,
      beam_agent_checkpoint_core,
      beam_agent_command_core,
      beam_agent_content_core,
      beam_agent_control_core,
      beam_agent_core,
      beam_agent_hooks_core,
      beam_agent_mcp_client_dispatch,
      beam_agent_mcp_dispatch,
      beam_agent_mcp_protocol,
      beam_agent_runtime_core,
      beam_agent_session_store_core,
      beam_agent_threads_core,
      beam_agent_tool_registry]}]}]}

.
{alias, [{check, [compile, dialyzer, {eunit, "-v"}, {ct, "-v"}]}]}

.
