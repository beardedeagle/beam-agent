{erl_opts, [
    debug_info,
    warn_missing_spec,
    warnings_as_errors
]}.

{src_dirs, [
    "src",
    "src/public",
    "src/core",
    "src/transports",
    "src/backends/claude",
    "src/backends/codex",
    "src/backends/copilot",
    "src/backends/gemini",
    "src/backends/opencode"
]}.

{deps, [
    {telemetry, "~> 1.3"},
    {gun, "~> 2.1"}
]}.

{dialyzer, [
    {warnings, [error_handling, underspecs, unmatched_returns]},
    {plt_extra_apps, [telemetry, gun]}
]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "~> 1.4"},
            {meck, "~> 0.9"}
        ]},
        {extra_src_dirs, [
            "test/contract",
            "test/conformance",
            "test/public",
            "test/core",
            "test/backends/claude",
            "test/backends/codex",
            "test/backends/copilot",
            "test/backends/gemini",
            "test/backends/opencode"
        ]},
        {erl_opts, [nowarn_export_all, nowarn_missing_spec]}
    ]}
]}.

{project_plugins, [
    {rebar3_hex, "~> 7.0"},
    {rebar3_ex_doc, "~> 0.2"}
]}.

{hex, [
    {doc, #{provider => ex_doc}}
]}.

{ex_doc, [
    {extras, [<<"README.md">>, <<"LICENSE">>]},
    {main, <<"README.md">>},
    {source_url, <<"https://github.com/beardedeagle/beam-agent">>}
]}.

{alias, [
    {check, [compile, dialyzer, {eunit, "-v"}, {ct, "-v"}]}
]}.
